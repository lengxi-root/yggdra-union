    <CheatEntry>
      <ID>174</ID>
      <Description>"经验倍率"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat
aobscanmodule(pExp_aob,YggdraUnion.exe,0F ** ** ** ** 66 89 47 02 80) // should be unique
alloc(newmem,$100,pExp_aob)

label(pExpcode)
label(return)
label(pExp)
registersymbol(pExpcode)
registersymbol(pExp)

newmem:
  reassemble(pExp_aob)
  imul eax,[pExp]
  jmp return

pExp:
  dd 1

pExpcode:
  reassemble(pExp_aob)

pExp_aob:
  jmp newmem
return:
registersymbol(pExp_aob)

[DISABLE]
//code from here till the end of the code will be used to disable the cheat
pExp_aob:
  reassemble(pExpcode)

unregistersymbol(*)
dealloc(*)

