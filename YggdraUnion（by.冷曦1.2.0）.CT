    <CheatEntry>
      <ID>70</ID>
      <Description>"无限移动力（不影响敌方）"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat
aobscanmodule(pMovementCount_aob,YggdraUnion.exe,0F ** ** ** ** ** ** 88 ** ** ** ** ** 3C 05) // should be unique
alloc(newmem,$100,pMovementCount_aob)

label(pMovementCountcode)
label(return)
registersymbol(pMovementCountcode)

newmem:
  mov ecx,#99
  jmp return

pMovementCountcode:
  readmem(pMovementCount_aob,7)

pMovementCount_aob:
  jmp newmem
  nop 2
return:
registersymbol(pMovementCount_aob)

[DISABLE]
//code from here till the end of the code will be used to disable the cheat
pMovementCount_aob:
  readmem(pMovementCountcode,7)

unregistersymbol(*)
dealloc(*)

