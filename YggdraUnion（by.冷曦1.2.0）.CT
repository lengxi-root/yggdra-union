<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>67</ID>
      <Description>"无限进攻（攻击前开启，失效时需重启游戏）"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat
aobscanmodule(pAttack_aob,YggdraUnion.exe,3c 04 76 08 3c 07 0f 85 ** ** ** **) // should be unique
alloc(newmem,$100,pAttack_aob)

label(pSkip1)
label(pSkip2)

newmem:
  mov rax,[YggdraUnion.exe+3DD280]
  test rax,rax
  jz pSkip1
  mov byte ptr [rax+56h],1
  mov byte ptr [rax+59h],1
pSkip1:
  mov rax,[YggdraUnion.exe+3DD278]
  test rax,rax
  jz pSkip2
  mov byte ptr [rax+56h],0
  mov byte ptr [rax+59h],0
pSkip2:
  jmp YggdraUnion.exe+8D6A8

pAttack_aob:
  jmp newmem
  nop
  nop
  nop
  nop
  nop
  nop
  nop
registersymbol(pAttack_aob)

[DISABLE]
//code from here till the end of the code will be used to disable the cheat
pAttack_aob:
  db 3c 04 76 08 3c 07 0f 85 91 01 00 00

unregistersymbol(*)
dealloc(*)

{
// ORIGINAL CODE - INJECTION POINT: YggdraUnion.exe+8D50B
// Hook at the charge function's type gate to bypass all character type
// and spirit restrictions, directly enabling player charge.
//
// Original issue: script only hooked the type-0 code path (lea+table check),
// but non-type-0 characters (including ArchAngel) never reached that code.
// Fix: hook at the type gate entry, force charge-enable flags on the two
// global battle objects, then jump to the function epilogue.

YggdraUnion.exe+8D4E0: 48 83 EC 38              - sub rsp,38
YggdraUnion.exe+8D4F3: 4C 8B 1D 1E EE 2D 00     - mov r11,[YggdraUnion.exe+3BC318]
YggdraUnion.exe+8D4FA: 4D 85 DB                  - test r11,r11
YggdraUnion.exe+8D4FD: 0F 84 A5 01 00 00         - je YggdraUnion.exe+8D6A8
YggdraUnion.exe+8D503: 41 0F B6 83 17 01 00 00   - movzx eax,byte ptr [r11+00000117]
// ---------- INJECTING HERE ----------
YggdraUnion.exe+8D50B: 3C 04                     - cmp al,04
YggdraUnion.exe+8D50D: 76 08                     - jbe YggdraUnion.exe+8D517
YggdraUnion.exe+8D50F: 3C 07                     - cmp al,07
YggdraUnion.exe+8D511: 0F 85 91 01 00 00         - jne YggdraUnion.exe+8D6A8
// ---------- DONE INJECTING  ----------
YggdraUnion.exe+8D517: 41 0F B6 93 17 01 00 00   - movzx edx,byte ptr [r11+00000117]
}
</AssemblerScript>
    </CheatEntry>
