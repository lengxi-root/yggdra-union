    <CheatEntry>
      <ID>500</ID>
      <Description>"卡片防闪退（修复死亡之吻，天雷，绝对零度，转生预言卡闪退）"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
globalalloc(textfix,128)
label(textfix_loop)
label(textfix_end)
label(textfix_null)

textfix:
  test rbx,rbx
  jz textfix_null
textfix_loop:
  db 0F B6 03
  db 88 84 0B 81 00 00 00
  db 48 8D 5B 01
  test al,al
  jne textfix_loop
  jmp textfix_end
textfix_null:
  db C6 87 81 00 00 00 00
textfix_end:
  jmp YggdraUnion.exe+33612

YggdraUnion.exe+33600:
  jmp textfix

globalalloc(idxfix,128)
label(idxfix_ok)
label(idxfix_fallback)
label(idxfix_continue)

idxfix:
  db 4C 8D 44 24 50
  db 0F 47 C8
  db 0F B6 C1
  cmp eax,3
  jbe idxfix_ok
  xor eax,eax
idxfix_ok:
  db 4D 8D 04 C0
  push rbx
  mov rbx,YggdraUnion.exe+3E5BF8
  mov rax,[rbx]
  pop rbx
  test rax,rax
  jz idxfix_fallback
  db 83 78 20 06
  jbe idxfix_fallback
  db 48 8B 40 50
  db 48 8B 88 E0 01 00 00
  jmp idxfix_continue
idxfix_fallback:
  mov rcx,rbx
idxfix_continue:
  jmp YggdraUnion.exe+1DBF8

YggdraUnion.exe+1DBCC:
  jmp idxfix
  db 90 90 90 90 90 90 90 90 90 90

globalalloc(cardfix,512)
label(cardfix_skip)

cardfix:
  push rax
  test rcx,rcx
  jz cardfix_skip

  mov rax,472F656C74746142
  cmp [rcx],rax
  jne cardfix_skip

  cmp byte ptr [rcx+11],33
  jne cardfix_skip
  cmp byte ptr [rcx+12],31
  jb cardfix_skip
  cmp byte ptr [rcx+12],36
  ja cardfix_skip
  mov byte ptr [rcx+12],34
  jmp cardfix_skip

cardfix_skip:
  pop rax
  mov [rsp+08],rbx
  mov [rsp+10],rbp
  mov [rsp+18],rsi
  push rdi
  jmp YggdraUnion.exe+77220

YggdraUnion.exe+77210:
  jmp cardfix

[DISABLE]
YggdraUnion.exe+33600:
  db 0F B6 03 88 84 0B 81 00 00 00 48 8D 5B 01 84 C0 75 EE
YggdraUnion.exe+1DBCC:
  db 4C 8D 44 24 50 0F 47 C8 0F B6 C1 4D 8D 04 C0
YggdraUnion.exe+77210:
  db 48 89 5C 24 08 48 89 6C 24 10 48 89 74 24 18 57
</AssemblerScript>
